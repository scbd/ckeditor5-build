{
  "name": "@scbd/ckeditor5-build-inline-full",
  "author": "SCBD",
  "description": "A custom CKEditor 5 build with most plugins",
  "version": "48.1.0",
  "license": "SEE LICENSE IN LICENSE.md",
  "private": false,
  "devDependencies": {
    "ckeditor5": "^48.1.0",
    "@ckeditor/ckeditor5-dev-utils": "^55.5.0",
    "css-loader": "^7.1.4",
    "mini-css-extract-plugin": "^2.10.2",
    "postcss-loader": "^8.2.1",
    "raw-loader": "^4.0.1",
    "terser-webpack-plugin": "^5.3.9",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4"
  },
  "engines": {
    "node": ">=12.0.0",
    "npm": ">=5.7.1"
  },
  "scripts": {
    "build:dev": "rm -rf ./build && webpack --mode development",
    "build": "rm -rf ./build && webpack --mode production",
    "clean": "rm -rf ./build",
    "publish": "npm publish . --access public",
    "build-publish": "npm run build && npm run publish",
    "clean-reinstall": "rm -rf ./node_modules ./build && npm install"
  }
}
